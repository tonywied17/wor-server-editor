{
  "name": "wor-server-editor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "node server.js",
    "start:client": "npm --prefix client run dev",
    "dev": "npm run start",
    "build": "npm --prefix client run build"
  },
  "dependencies": {
    "molex-ftp": "^2.3.1",
    "molex-xml-js": "^0.3.3",
    "zero-http": "^0.8.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
